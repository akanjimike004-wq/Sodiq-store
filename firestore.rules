rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this project, we'll treat any authenticated user as staff/admin 
      // since it's an internal management tool requested.
      // In production, we'd check a specific collection.
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isStaff() {
      return isSignedIn(); // Simplification for internal-focused dev
    }

    // --- Entity Validations ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0 &&
             data.sku is string && data.sku.size() <= 100;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() <= 200 &&
             data.total is number && data.total >= 0 &&
             data.status in ["pending", "processing", "shipped", "delivered", "cancelled", "returned"];
    }

    function isValidReturn(data) {
      return data.orderId is string &&
             data.status in ["pending", "received", "inspected", "completed"];
    }

    // --- Rules ---

    match /test/connection {
      allow read: if true;
    }

    match /products/{productId} {
      // Publicly viewable catalog
      allow get, list: if true;
      
      // Staff only management
      allow create: if isStaff() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isStaff() && isValidProduct(incoming()) && (
        // Action: Generic update
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'stock', 'sku', 'imageUrl', 'updatedAt'])
      );
      allow delete: if isStaff();
    }

    match /orders/{orderId} {
      // Orders are for staff eyes only
      allow read: if isStaff();
      allow create: if isStaff() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isStaff() && isValidOrder(incoming()) && (
        // Action: Update status or items
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'items', 'total', 'customerName', 'customerPhone'])
      );
      allow delete: if isStaff();
    }

    match /returns/{returnId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidReturn(incoming()) && isValidId(returnId);
      allow update: if isStaff() && isValidReturn(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'items', 'reason', 'updatedAt'])
      );
      allow delete: if isStaff();
    }
  }
}
