{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory item for the fashion studio",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the product" },
        "description": { "type": "string", "description": "Long description of the garment" },
        "price": { "type": "number", "description": "Unit price" },
        "category": { "type": "string", "description": "Fashion category" },
        "stock": { "type": "integer", "description": "Current quantity in stock" },
        "sku": { "type": "string", "description": "Stock Keeping Unit" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Product display image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "sku"]
    },
    "Order": {
      "title": "Order",
      "description": "Client order tracking",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { 
          "type": "array", 
          "description": "List of items in the order"
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled", "returned"] },
        "whatsappLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "items", "total", "status"]
    },
    "Return": {
      "title": "Return",
      "description": "Managed returns and exchanges",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "items": { "type": "array" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "received", "inspected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "items", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Primary inventory collection"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history"
    },
    "/returns/{returnId}": {
      "schema": "Return",
      "description": "Tracking for returns and exchanges"
    }
  }
}
